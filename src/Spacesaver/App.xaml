<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Spacesaver.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Spacesaver"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="SemanticGoodBrush" Color="#66BB6A" />
            <SolidColorBrush x:Key="SemanticImportantBrush" Color="#FFA726" />
            <SolidColorBrush x:Key="SemanticAttentionBrush" Color="#FFD54F" />
            <SolidColorBrush x:Key="SemanticInformativeBrush" Color="#64B5F6" />

            <SolidColorBrush x:Key="SemanticGoodTintBrush" Color="#1A66BB6A" />
            <SolidColorBrush x:Key="SemanticImportantTintBrush" Color="#1AFFA726" />
            <SolidColorBrush x:Key="SemanticAttentionTintBrush" Color="#1AFFD54F" />
            <SolidColorBrush x:Key="SemanticInformativeTintBrush" Color="#1A64B5F6" />

            <TransitionCollection x:Key="StaggeredEntranceTransitions">
                <EntranceThemeTransition FromVerticalOffset="20" IsStaggeringEnabled="True" />
                <RepositionThemeTransition IsStaggeringEnabled="True" />
            </TransitionCollection>
        </ResourceDictionary>
    </Application.Resources>
</Application>
