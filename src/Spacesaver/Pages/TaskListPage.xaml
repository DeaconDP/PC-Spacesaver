<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Spacesaver.Pages.TaskListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32,24,32,32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock
                x:Name="HeaderText"
                FontSize="28"
                FontWeight="SemiBold"
                Text="All Tasks" />
            <TextBlock
                x:Name="SubtitleText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Select a task to see step-by-step guidance." />
        </StackPanel>

        <ListView
            x:Name="TaskListView"
            Grid.Row="1"
            ItemContainerTransitions="{StaticResource StaggeredEntranceTransitions}"
            IsItemClickEnabled="True"
            ItemClick="TaskListView_ItemClick"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid
                        Padding="16,12"
                        ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                            <FontIcon
                                VerticalAlignment="Center"
                                FontSize="18"
                                Foreground="{Binding RiskBrush}"
                                Glyph="{Binding Task.IconGlyph}" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="{Binding Task.Title}" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding Subtitle}" />
                        </StackPanel>

                        <Border
                            Grid.Column="2"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Background="{Binding RiskTintBrush}"
                            BorderBrush="{Binding RiskBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{Binding RiskBrush}"
                                Text="{Binding Task.RiskLabel}" />
                        </Border>

                        <FontIcon
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="{StaticResource SemanticGoodBrush}"
                            Glyph="&#xE73E;"
                            Visibility="{Binding DoneIconVisibility}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
