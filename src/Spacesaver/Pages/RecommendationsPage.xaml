<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Spacesaver.Pages.RecommendationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32,24,32,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="HeaderPanel" Spacing="8">
            <TextBlock
                FontSize="28"
                FontWeight="SemiBold"
                Text="Recommendations" />
            <TextBlock
                x:Name="DriveSummaryText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Scanning your drive…"
                TextWrapping="WrapWholeWords" />
            <ProgressBar
                x:Name="DriveUsageBar"
                Maximum="100"
                Value="0" />
        </StackPanel>

        <InfoBar
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True"
            Message="Green = safe and high value. Orange = important. Yellow = needs your attention. Blue = optional or informational. Safe deletions run in this app; other actions open Windows tools for you to confirm."
            Severity="Informational"
            Title="How to read this list" />

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressRing
                x:Name="ScanProgressRing"
                Width="32"
                Height="32"
                IsActive="True" />

            <TextBlock
                x:Name="ScanStatusText"
                Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Starting scan…"
                TextWrapping="WrapWholeWords" />

            <Button
                x:Name="RescanButton"
                Grid.Column="2"
                Click="RescanButton_Click"
                Content="Scan again"
                Visibility="Collapsed" />
        </Grid>

        <ListView
            x:Name="RecommendationsList"
            Grid.Row="3"
            ItemContainerTransitions="{StaticResource StaggeredEntranceTransitions}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="0,0,0,8"
                        Background="{Binding ImpactTintBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <Border
                                Width="4"
                                HorizontalAlignment="Left"
                                Background="{Binding ImpactBrush}"
                                CornerRadius="8,0,0,8" />

                            <Grid Padding="16,12,16,12" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox
                                    VerticalAlignment="Top"
                                    IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                <StackPanel Grid.Column="1" Spacing="6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{Binding Title}"
                                            TextWrapping="WrapWholeWords" />

                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Foreground="{Binding ImpactBrush}"
                                            Text="{Binding FormattedSize}"
                                            Visibility="{Binding SizeVisibility}" />
                                    </Grid>

                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding ScanDetail}"
                                        TextWrapping="WrapWholeWords" />

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border
                                            Padding="8,2"
                                            Background="{Binding ImpactBrush}"
                                            CornerRadius="4">
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding ImpactLabel}" />
                                        </Border>
                                        <Border
                                            Padding="8,2"
                                            Background="{Binding RiskBrush}"
                                            CornerRadius="4">
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding RiskLabel}" />
                                        </Border>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="{Binding ExecutionForeground}"
                                            Text="{Binding ExecutionLabel}" />
                                    </StackPanel>

                                    <TextBlock
                                        FontSize="13"
                                        Text="{Binding RiskSummary}"
                                        TextWrapping="WrapWholeWords" />

                                    <HyperlinkButton
                                        Click="LearnMore_Click"
                                        Content="Learn more"
                                        Tag="{Binding TaskId}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border
            x:Name="ApplyFooter"
            Grid.Row="4"
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center" Spacing="4">
                    <TextBlock
                        x:Name="SelectionSummaryText"
                        FontWeight="SemiBold"
                        Text="0 selected" />
                    <TextBlock
                        x:Name="ApplyStatusText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                </StackPanel>

                <Button
                    x:Name="ApplyButton"
                    Grid.Column="1"
                    Click="ApplyButton_Click"
                    Content="Apply Selected"
                    IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Page>
