<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Spacesaver.Pages.TaskDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="32,24,32,32" Spacing="20">
            <StackPanel x:Name="TaskHeaderPanel" Spacing="8">
                <TextBlock
                    x:Name="TaskNumberText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Task #1" />
                <TextBlock
                    x:Name="TitleText"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="Task title"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    x:Name="DescriptionText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Description"
                    TextWrapping="WrapWholeWords" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border
                        x:Name="SavingsBorder"
                        Padding="10,4"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        CornerRadius="4">
                        <TextBlock x:Name="SavingsText" Text="1–5 GB" />
                    </Border>
                    <Border
                        x:Name="RiskBorder"
                        Padding="10,4"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        CornerRadius="4">
                        <TextBlock x:Name="RiskText" Text="Safe" />
                    </Border>
                    <Border
                        x:Name="CategoryBorder"
                        Padding="10,4"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        CornerRadius="4">
                        <TextBlock x:Name="CategoryText" Text="Quick Wins" />
                    </Border>
                </StackPanel>
            </StackPanel>

            <InfoBar
                x:Name="AdminInfoBar"
                IsClosable="False"
                IsOpen="False"
                Message="This step requires Administrator privileges. Run the opened tool as admin when prompted."
                Severity="Warning"
                Title="Administrator required" />

            <InfoBar
                x:Name="WarningInfoBar"
                IsClosable="False"
                IsOpen="False"
                Severity="Error"
                Title="Read before proceeding" />

            <StackPanel x:Name="StepsPanel" Spacing="12">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Steps" />
                <ItemsControl x:Name="StepsList" />
            </StackPanel>

            <StackPanel x:Name="ActionPanel" Orientation="Horizontal" Spacing="12">
                <Button
                    x:Name="OpenToolButton"
                    Click="OpenToolButton_Click"
                    Content="Open Tool"
                    Style="{StaticResource AccentButtonStyle}" />
                <Button
                    x:Name="CopyCommandButton"
                    Click="CopyCommandButton_Click"
                    Content="Copy Command"
                    Visibility="Collapsed" />
            </StackPanel>

            <ToggleSwitch
                x:Name="DoneToggle"
                OffContent="Mark as not done"
                OnContent="Marked as done"
                Toggled="DoneToggle_Toggled" />
        </StackPanel>
    </ScrollViewer>
</Page>
