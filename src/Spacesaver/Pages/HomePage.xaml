<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Spacesaver.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="32,24,32,32" RowSpacing="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel x:Name="HeaderPanel" Spacing="8">
                <TextBlock
                    FontSize="32"
                    FontWeight="SemiBold"
                    Text="PC Spacesaver" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Scan your drive for tailored recommendations. Safe cleanups run in-app; everything else opens built-in Windows tools so you stay in control."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Border
                x:Name="ProgressCard"
                Grid.Row="1"
                Padding="24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ProgressRing
                        x:Name="ProgressRing"
                        Width="72"
                        Height="72"
                        VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <TextBlock
                            x:Name="ProgressText"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="0 of 20 complete" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Work through the checklist at your own pace. Mark tasks done as you finish them."
                            TextWrapping="WrapWholeWords" />
                        <StackPanel Margin="0,8,0,0" Spacing="8">
                            <Button
                                x:Name="ScanButton"
                                Click="ScanRecommendations_Click"
                                Content="Scan for Recommendations"
                                Style="{StaticResource AccentButtonStyle}" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                FontSize="12"
                                Text="Analyze your drive and pick what to clean."
                                TextWrapping="WrapWholeWords" />
                            <Button
                                Click="StartQuickWins_Click"
                                Content="Start with Quick Wins" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel x:Name="CategoriesPanel" Grid.Row="2" Spacing="12">
                <TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="Categories" />
                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button
                        x:Name="QuickWinsButton"
                        MinHeight="96"
                        Click="QuickWins_Click"
                        Style="{StaticResource DefaultButtonStyle}">
                        <StackPanel Spacing="4">
                            <FontIcon FontSize="20" Glyph="&#xE945;" />
                            <TextBlock FontWeight="SemiBold" Text="Quick Wins" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="5 safe tasks · ~5 min" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="SystemCleanupButton"
                        Grid.Column="1"
                        MinHeight="96"
                        Click="SystemCleanup_Click"
                        Style="{StaticResource DefaultButtonStyle}">
                        <StackPanel Spacing="4">
                            <FontIcon FontSize="20" Glyph="&#xE7EF;" />
                            <TextBlock FontWeight="SemiBold" Text="System Cleanup" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="5 admin tasks · ~10 min" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="LargeWinsButton"
                        Grid.Row="1"
                        MinHeight="96"
                        Click="LargeWins_Click"
                        Style="{StaticResource DefaultButtonStyle}">
                        <StackPanel Spacing="4">
                            <FontIcon FontSize="20" Glyph="&#xE7FC;" />
                            <TextBlock FontWeight="SemiBold" Text="Large Space Wins" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="5 caution tasks · read warnings" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="ManualReviewButton"
                        Grid.Row="1"
                        Grid.Column="1"
                        MinHeight="96"
                        Click="ManualReview_Click"
                        Style="{StaticResource DefaultButtonStyle}">
                        <StackPanel Spacing="4">
                            <FontIcon FontSize="20" Glyph="&#xE7B8;" />
                            <TextBlock FontWeight="SemiBold" Text="Manual Review" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="5 tasks · your judgment" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <InfoBar
                x:Name="SafetyInfoBar"
                Grid.Row="3"
                IsClosable="False"
                IsOpen="True"
                Message="Safe actions (like emptying Recycle Bin and old Temp files) can run in this app after you confirm. Riskier actions open Windows tools — nothing is deleted without your approval. Avoid third-party registry cleaners and never manually delete WinSxS or Prefetch folders."
                Severity="Informational"
                Title="Safe by design" />
        </Grid>
    </ScrollViewer>
</Page>
