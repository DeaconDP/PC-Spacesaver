<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Spacesaver.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="32,24,32,32" Spacing="24">
            <StackPanel x:Name="HeaderPanel" Spacing="8">
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="Settings" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Manage your cleanup checklist progress."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Border
                x:Name="ProgressCard"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="16">
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Progress" />
                    <TextBlock
                        x:Name="ProgressSummaryText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="0 of 20 tasks marked complete" />
                    <Button
                        Click="ResetProgress_Click"
                        Content="Reset all progress" />
                </StackPanel>
            </Border>

            <Border
                x:Name="SafetyCard"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="What this app does not recommend" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        LineHeight="22"
                        Text="• Third-party registry cleaners or &quot;PC optimizer&quot; tools&#x0a;• Manually deleting C:\Windows\WinSxS&#x0a;• Deleting C:\Windows\Prefetch&#x0a;• Bulk-deleting Downloads without reviewing contents"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="PC Spacesaver v1.0 · Guided cleanup using built-in Windows tools"
                TextWrapping="WrapWholeWords" />
        </StackPanel>
    </ScrollViewer>
</Page>
